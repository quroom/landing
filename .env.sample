DJANGO_DEBUG=1
DJANGO_SECRET_KEY=dev-only-change-me
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost
DJANGO_CSRF_TRUSTED_ORIGINS=http://127.0.0.1:8000
# Database (production): set either DATABASE_URL or PG*/DB* variables.
# DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require
# PGHOST=
# PGPORT=5432
# PGDATABASE=
# PGUSER=
# PGPASSWORD=
# DB_HOST=
# DB_PORT=5432
# DB_NAME=
# DB_USER=
# DB_PASSWORD=
DJANGO_EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# Debug-only safety switch:
# - DEBUG=1 and 0 -> force console backend (real send blocked)
# - DEBUG=1 and 1 -> allow real SMTP
# - DEBUG=0 -> ignored (production follows DJANGO_EMAIL_BACKEND directly)
DJANGO_ALLOW_REAL_EMAIL_IN_DEBUG=0
# Keep 0 to force synchronous send. Set to 1 to allow async send.
DJANGO_ALLOW_ASYNC_EMAIL_IN_DEBUG=0
EMAIL_HOST=smtp.daum.net
EMAIL_PORT=465
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=0
EMAIL_USE_SSL=1
DJANGO_DEFAULT_FROM_EMAIL=큐룸 <help@quroom.kr>
QUROOM_CONTACT_EMAIL=
# Base default is async on, but settings.py forces it off when
# DJANGO_ALLOW_REAL_EMAIL_IN_DEBUG=0.
CONTACT_EMAIL_ASYNC=1
DJANGO_SITE_BASE_URL=http://127.0.0.1:8000
